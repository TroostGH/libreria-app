rules_version = '2';

// Accesso pubblico (lettura e scrittura) — l'utente ha scelto modalità senza
// autenticazione. Se in futuro vuoi limitare l'editing solo a te, sostituisci
// con regole basate su `request.auth.uid`.
service cloud.firestore {
  match /databases/{database}/documents {
    match /books/{bookId} {
      allow read, write: if true;
    }
  }
}
